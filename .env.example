# Local docker-compose development only. Copy to .env and fill in values.
# Production (Coolify) sets these directly via its env API instead of this
# file — see docker-compose.yml's `env_file: .env (required: false)`.

POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=ata_rag_chat
DATABASE_URL=postgresql://appuser:apppassword@db:5432/ata_rag_chat

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
EMBEDDING_MODEL=text-embedding-3-small

CRAWL_BASE_URL=https://akademiata.pl

BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

CONFIDENCE_THRESHOLD=0.55
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
